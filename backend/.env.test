APP_ENV=test

# Эти переменные будут прочитаны pydantic-settings в core/config.py
POSTGRES_USER=postgres
POSTGRES_PASSWORD=code1234
POSTGRES_SERVER=localhost
POSTGRES_PORT=5432
POSTGRES_DB=test_meetings_db

# Можно также предоставить полную DATABASE_URL, тогда она будет иметь приоритет
# DATABASE_URL=postgresql://postgres:code1234@localhost:5432/test_meetings_db?client_encoding=utf8